# Native Grace FieldOS — local Phase 1 example
# Copy to .env and adjust. Never commit real secrets.

FIELDOS_ENV=development
FIELDOS_BASE_URL=http://localhost:8080
LOG_LEVEL=INFO

# mock = local demo data (default for Docker). sheets = reserved (not enabled in Phase 1 local build).
DATA_MODE=mock

# Replace before any shared/staging use
JWT_SECRET=replace-with-long-random-string
JWT_EXPIRE_MINUTES=720

# Demo login (bcrypt-hashed at first boot into AUTH_USERS_FILE)
DEMO_STAFF_EMAIL=alex@nativegrace.com
DEMO_STAFF_PASSWORD=FieldOS-Demo-2026!
DEMO_STAFF_ID=STAFF-DEMO001
DEMO_STAFF_NAME=Alex Technician

# Sheet column assumptions (not confirmed in Apps Script export)
JOB_ASSIGNMENT_COLUMN=assigned_staff_id
JOB_DATE_COLUMN=job_date
JOB_PROJECT_COLUMN=project_name
JOB_CUSTOMER_COLUMN=customer_name
JOBS_DEFAULT_DAYS=7

MAX_UPLOAD_MB=25
ALLOWED_AUDIO_MIMES=audio/webm,audio/mp4,audio/mpeg,audio/ogg,audio/wav,video/webm

CORS_ORIGINS=http://localhost:8080,http://localhost:5173

# Optional — leave blank for simulated process responses in mock mode
APPS_SCRIPT_WEBAPP_URL=
APPS_SCRIPT_WEBHOOK_SECRET=
APPS_SCRIPT_TIMEOUT_SECONDS=30

# Used only when DATA_MODE=sheets (future)
SPREADSHEET_ID=
RECORDINGS_FOLDER_ID=
GOOGLE_APPLICATION_CREDENTIALS=
