# Native Grace FieldOS — local / Phase 2 example
# Copy to .env and adjust. Never commit real secrets.
# Do not overwrite a working .env blindly — merge keys carefully.

FIELDOS_ENV=development
FIELDOS_BASE_URL=http://localhost:8080
LOG_LEVEL=INFO

# mock = local demo data (default)
# apps_script = FastAPI → Apps Script gateway + Drive uploads + process_voice_dictation
DATA_MODE=mock

# Replace before any shared/staging use
JWT_SECRET=replace-with-long-random-string
JWT_EXPIRE_MINUTES=720

# Demo login (bcrypt-hashed at first boot into AUTH_USERS_FILE)
DEMO_STAFF_EMAIL=alex@nativegrace.com
DEMO_STAFF_PASSWORD=FieldOS-Demo-2026!
# For live apps_script smoke, use a real tbl_job_sheets.staff_id (verified: STAFF-9012C021)
DEMO_STAFF_ID=STAFF-DEMO001
DEMO_STAFF_NAME=Alex Technician

# Sheet column mappings — confirmed live tbl_job_sheets headers
# assignment=staff_id, date=date, project=project_id
# customer_name is NOT on the job sheet; kept for API display until project→customer lookup
JOB_ASSIGNMENT_COLUMN=staff_id
JOB_DATE_COLUMN=date
JOB_PROJECT_COLUMN=project_id
JOB_CUSTOMER_COLUMN=customer_name
JOBS_DEFAULT_DAYS=7

MAX_UPLOAD_MB=25
ALLOWED_AUDIO_MIMES=audio/webm,audio/mp4,audio/mpeg,audio/ogg,audio/wav,video/webm

CORS_ORIGINS=http://localhost:8080,http://localhost:5173

# Apps Script (server-side only — never expose to browser)
APPS_SCRIPT_WEBAPP_URL=
APPS_SCRIPT_WEBHOOK_SECRET=
APPS_SCRIPT_TIMEOUT_SECONDS=30

# Required for DATA_MODE=apps_script recording uploads (Drive from FastAPI, then register_recording).
# - Use a Shared Drive folder ID (service accounts need Shared Drive + supportsAllDrives).
# - FieldOS uses full Drive scope https://www.googleapis.com/auth/drive (drive.file is insufficient).
# - Place JSON at fieldos/secrets/service-account.json (gitignored; compose mounts to /app/secrets/...).
# - Share the Shared Drive / folder with the service account as Content manager.
# - Never commit secrets/ or real .env values.
RECORDINGS_FOLDER_ID=
GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/service-account.json

# Optional / unused by Phase 2 job reads (Apps Script uses its own SPREADSHEET_ID Script Property)
SPREADSHEET_ID=
